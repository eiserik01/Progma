# Zkopírujte tento soubor jako .env.local a vyplňte skutečné hodnoty
# z Supabase Dashboardu (Project Settings → API).
#
# .env.local se NIKDY nenahrává do gitu (je v .gitignore) — hodnoty musíte
# ručně vyplnit i v nastavení Vercel projektu pro Progma OS (Settings →
# Environment Variables), jinak appka na produkci nebude vědět, ke které
# databázi se připojit.

VITE_SUPABASE_URL=https://vaseprojectref.supabase.co
VITE_SUPABASE_ANON_KEY=vas-anon-public-klic
